<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body, html { 
            width: 100%; height: 100%; overflow: hidden; 
            background-color: transparent !important; 
            display: flex; justify-content: center; align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            color: #37352f; /* Standard Notion text color (use #FFFFFF for dark mode) */
        }
        
        #photo-name {
            font-size: 16px; font-weight: 500; text-align: center;
            opacity: 0; transition: opacity 0.4s ease-in-out;
        }
        
        .visible { opacity: 1 !important; }
    </style>
</head>
<body>
    
    <div id="photo-name"></div>

    <script>
        const nameDisplay = document.getElementById('photo-name');

        function updateName(newName) {
            if (newName) {
                nameDisplay.innerText = newName;
                nameDisplay.classList.add('visible');
            }
        }

        // 1. Check if the image widget already saved a name on page load
        const existingName = localStorage.getItem('shared_photo_name');
        updateName(existingName);

        // 2. Listen continuously! If the image widget reloads and picks a new photo, this updates instantly.
        window.addEventListener('storage', (event) => {
            if (event.key === 'shared_photo_name') {
                updateName(event.newValue);
            }
        });
    </script>
</body>
</html>
