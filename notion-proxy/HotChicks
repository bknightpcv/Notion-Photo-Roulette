<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Complete CSS Reset to remove all default browser borders and margins */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            border: none;
            outline: none;
        }
        
        /* Force total transparency so Notion's background shows through */
        body, html { 
            width: 100%; 
            height: 100%; 
            overflow: hidden; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            background-color: transparent !important; 
        }
        
        /* Image starts completely invisible (opacity: 0) and fades in smoothly */
        img { 
            max-width: 100%; 
            max-height: 100%; 
            object-fit: cover; 
            border-radius: 8px; /* Matches Notion's rounded corner style */
            opacity: 0; 
            transition: opacity 0.4s ease-in-out; 
            display: block;
            border: none;
        }
        
        /* Class applied only after the image has completely downloaded */
        .visible { 
            opacity: 1; 
        }
    </style>
</head>
<body>
    <img id="random-image" alt="">

    <script>
        // Keep your working relative API path!
        const API_ENDPOINT = "/api/photos"; 

        async function loadImg() {
            try {
                const res = await fetch(API_ENDPOINT);
                if (!res.ok) return;
                
                const urls = await res.json();
                if (!urls || urls.length === 0) return;
                
                const img = document.getElementById('random-image');
                img.src = urls[Math.floor(Math.random() * urls.length)];
                
                // Once the image file is fully downloaded, fade it into view
                img.onload = () => img.classList.add('visible');
            } catch (e) { 
                console.error("Widget load error:", e); 
            }
        }
        
        window.onload = loadImg;
    </script>
</body>
</html>
